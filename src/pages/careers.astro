---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const navLinks = [
  { href: '#life', label: 'Life Here' },
  { href: '#benefits', label: 'Benefits' },
  { href: '#openings', label: 'Openings' },
  { href: '#process', label: 'Process' },
];

const heroStats = [
  { value: '14', label: 'Day Hiring' },
  { value: '1:1', label: 'Mentor-Led' },
  { value: 'Hybrid', label: 'Remote Friendly' },
];

const featured = [
  { title: 'Salesforce Developer', loc: 'Bangalore / Remote', exp: '2+ YRS' },
  { title: 'Salesforce Admin', loc: 'Bangalore / Remote', exp: '1+ YR' },
  { title: 'Quality Analyst', loc: 'Bangalore / Remote', exp: '1+ YR' },
  { title: 'Trainee Developer', loc: 'Bangalore / Remote', exp: 'FRESHER' },
];

const reasons = [
  {
    n: '1',
    title: 'Learn from Scratch',
    body: 'Fresh graduates get structured Salesforce training — and many engineers start with no CRM background and grow into certified professionals.',
    tags: ['Fundamentals', 'Apex', 'LWC', 'Flow Automation', 'Best practices'],
  },
  {
    n: '2',
    title: 'Real Ownership',
    body: 'Own features from design to deployment, interact directly with clients, and ship production-ready solutions with mentor guidance.',
    tags: [],
  },
  {
    n: '3',
    title: 'Diverse Projects',
    body: 'Hands-on across consulting, enterprise CRM implementations, AppExchange products, API integrations, automation and solution architecture.',
    tags: ['Consulting', 'Integrations', 'AppExchange', 'Architecture'],
  },
  {
    n: '4',
    title: 'Career Growth',
    body: 'Clear, merit-based progression with internal promotions encouraged at every level.',
    tags: ['Trainee → Developer', 'Dev → Senior', 'QA → QA Lead', 'Senior → Tech Lead'],
  },
  {
    n: '5',
    title: 'Collaborative Culture',
    body: 'Open communication, minimal hierarchy, high ownership and fast feedback loops — built for collaborative problem solving.',
    tags: [],
  },
  {
    n: '6',
    title: 'Continuous Learning',
    body: 'A dedicated learning budget, Trailhead support and certification sponsorship keep your skills compounding.',
    tags: ['Learning budget', 'Trailhead', 'Certifications'],
  },
];

const benefits = [
  'Salesforce certification sponsorship',
  'Flexible working hours',
  'Hybrid / remote work opportunities',
  'Mentorship from experienced professionals',
  'Exposure to enterprise client projects',
  'Team outings and celebrations',
  'Performance-based appraisal cycles',
  'Dedicated learning budget',
  'Trailhead learning support',
  'Career development programs',
];

const jobs = [
  { dept: 'Business', title: 'Operations Executive', loc: 'Bangalore / Remote', exp: 'Fresher', type: 'Full-time' },
  { dept: 'Business', title: 'Business Development Executive', loc: 'Bangalore / Remote', exp: 'Internship', type: '3–6 months' },
  { dept: 'Business', title: 'Associate Project Manager L1', loc: 'Bangalore / Remote', exp: 'Internship', type: '1 year' },
  { dept: 'Business', title: 'HR Specialist', loc: 'Bangalore / Remote', exp: '2.5–3 years', type: 'Full-time' },
  { dept: 'Engineering', title: 'Associate Salesforce Developer L1', loc: 'Bangalore / Remote', exp: '0–6 months', type: 'Internship' },
  { dept: 'Engineering', title: 'Senior CPQ Developer', loc: 'Bangalore / Remote', exp: '6+ years', type: 'Full-time' },
  { dept: 'Engineering', title: 'Animator', loc: 'Bangalore / Remote', exp: '1+ year', type: 'Full-time' },
  { dept: 'Engineering', title: 'Accounts Payable Executive', loc: 'Bangalore / Remote', exp: '0–6 months', type: 'Internship' },
  { dept: 'Quality', title: 'Associate Quality Analyst L1', loc: 'Bangalore / Remote', exp: 'Fresher', type: 'Full-time' },
  { dept: 'Quality', title: 'Quality Analyst', loc: 'Bangalore / Remote', exp: '3+ years', type: 'Full-time' },
];

const tabNames = ['All', 'Business', 'Engineering', 'Quality'];
const depts = tabNames.map((label) => ({
  label,
  count: label === 'All' ? jobs.length : jobs.filter((j) => j.dept === label).length,
}));

const steps = [
  { n: '01', days: 'DAY 1–3', title: 'Initial Conversation', body: 'A 20–30 min intro to learn about your experience and goals, and to introduce MiraiForge and the role.' },
  { n: '02', days: 'DAY 5–7', title: 'Technical Assessment', body: 'Role-dependent evaluation across Salesforce fundamentals, Apex, LWC, Flows and problem-solving.' },
  { n: '03', days: 'DAY 8–10', title: 'Practical Assignment', body: 'A short real-world assignment to demonstrate practical implementation skills and technical thinking.' },
  { n: '04', days: 'DAY 12–14', title: 'Final Interview & Offer', body: 'A final discussion with leadership, followed by an offer if there’s a strong mutual fit.' },
];

const expertise = [
  'Salesforce Consulting', 'Implementation', 'Custom Development', 'Enterprise Integrations',
  'AppExchange Products', 'CRM Modernization', 'Automation Solutions', 'Customer Success',
];

const seal = `<svg width="20" height="20" viewBox="0 0 120 120" fill="none"><rect x="5" y="5" width="110" height="110" rx="24" fill="var(--ink)"></rect><g transform="translate(60 60)"><path d="M0 0 L0 -34 L17 -18 Z" fill="var(--paper)"></path><path d="M0 0 L0 -34 L17 -18 Z" fill="var(--paper)" transform="rotate(120)"></path><path d="M0 0 L0 -34 L17 -18 Z" fill="var(--accent)" transform="rotate(240)"></path><circle r="6" fill="var(--ink)"></circle></g></svg>`;
---

<Base
  title="Careers — MiraiForge Technologies"
  description="Forge a Salesforce career that's built to last. Open roles in engineering, business and quality at MiraiForge Technologies — certification sponsored, hybrid friendly."
>
  <Nav links={navLinks} ctaHref="#openings" ctaLabel="View roles" />

  <!-- ============================ HERO ============================ -->
  <section id="top" class="hero">
    <div class="hero__kanji" aria-hidden="true">未来</div>
    <div class="hero__inner">
      <span class="mono-label hero__eyebrow">Careers at MiraiForge Technologies</span>
      <h1 class="hero__title">
        Forge a Salesforce career<br />
        that's <span class="hero__title-accent">built to last</span>.
      </h1>
      <p class="hero__lede">
        From fresh graduates to seasoned architects — we help people build
        rewarding careers through structured learning, mentorship, and real
        enterprise client exposure.
      </p>
      <div class="hero__cta">
        <a href="#openings" class="btn btn--primary">See open positions</a>
        <a href="#life" class="btn btn--ghost">Why MiraiForge</a>
      </div>

      <div class="hero__stats">
        {heroStats.map((s) => (
          <div class="hero__stat">
            <span class="hero__stat-value">{s.value}</span>
            <span class="mono-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= FEATURED ROLES ========================= -->
  <section class="section">
    <div class="featured__head">
      <div>
        <div class="section-tag">
          <span class="num">·</span>
          <span class="name">Featured Roles</span>
        </div>
        <h2 class="section-heading">Roles we're hiring for now</h2>
      </div>
      <a href="#openings" class="featured__all">See all open positions →</a>
    </div>

    <div class="featured__grid">
      {featured.map((r) => (
        <a class="rolecard" href={`/apply?role=${encodeURIComponent(r.title)}`}>
          <div class="rolecard__top">
            <span class="chip chip--accent">{r.exp}</span>
            <span class="rolecard__seal" set:html={seal} />
          </div>
          <div class="rolecard__meta">
            <h3 class="rolecard__title">{r.title}</h3>
            <span class="rolecard__loc">{r.loc}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ========================= LIFE AT MIRAIFORGE ========================= -->
  <section id="life" class="section section--ink">
    <div class="ink-head">
      <span class="mono-label ink-head__eyebrow">Life at MiraiForge</span>
      <h2 class="section-heading section-heading--center">Six reasons people stay &amp; grow</h2>
    </div>

    <div class="reasons">
      {reasons.map((r) => (
        <article class="reason">
          <div class="reason__head">
            <span class="reason__n">{r.n}</span>
            <h3 class="reason__title">{r.title}</h3>
          </div>
          <p class="reason__body">{r.body}</p>
          {r.tags.length > 0 && (
            <div class="reason__tags">
              {r.tags.map((t) => <span class="tag tag--ink">{t}</span>)}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <!-- ============================ BENEFITS ============================ -->
  <section id="benefits" class="section">
    <div class="benefits">
      <div class="benefits__lead">
        <div class="section-tag">
          <span class="num">·</span>
          <span class="name">Benefits &amp; Perks</span>
        </div>
        <h2 class="section-heading">Invested in your growth, on and off the clock.</h2>
        <p class="section-sub">
          We back our team with the time, budget, and mentorship to keep
          levelling up — and the flexibility to do great work from anywhere.
        </p>
      </div>
      <div class="benefits__grid">
        {benefits.map((b) => (
          <div class="benefit">
            <span class="benefit__mark">✦</span>
            <span>{b}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= OPEN POSITIONS ========================= -->
  <section id="openings" class="section section--alt">
    <div class="ink-head ink-head--light">
      <span class="mono-label ink-head__eyebrow">Current Open Positions</span>
      <h2 class="section-heading section-heading--center">{jobs.length} roles, three teams</h2>
    </div>

    <div class="tabs" role="tablist">
      {depts.map((d, i) => (
        <button
          class={`tab${i === 0 ? ' is-active' : ''}`}
          data-dept-tab={d.label}
          type="button"
        >
          {d.label === 'All' ? 'All roles' : d.label} · {d.count}
        </button>
      ))}
    </div>

    <div class="listings">
      {jobs.map((job) => (
        <div class="listing" data-dept-job={job.dept}>
          <div class="listing__main">
            <div class="listing__titlerow">
              <span class="chip chip--accent">{job.dept}</span>
              <h3 class="listing__title">{job.title}</h3>
            </div>
            <div class="listing__facts">
              <span>◷ {job.loc}</span>
              <span>★ {job.exp}</span>
              <span>▸ {job.type}</span>
            </div>
          </div>
          <a href={`/apply?role=${encodeURIComponent(job.title)}`} class="listing__apply">Apply →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ========================= HIRING PROCESS ========================= -->
  <section id="process" class="section">
    <div class="ink-head ink-head--light">
      <span class="mono-label ink-head__eyebrow">Hiring Process</span>
      <h2 class="section-heading section-heading--center">From hello to offer in ~2 weeks</h2>
    </div>

    <div class="steps">
      {steps.map((s) => (
        <article class="hstep">
          <div class="hstep__top">
            <span class="hstep__n">{s.n}</span>
            <span class="hstep__days">{s.days}</span>
          </div>
          <h3 class="hstep__title">{s.title}</h3>
          <p class="hstep__body">{s.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ========================= POSITIONING ========================= -->
  <section class="section section--ink">
    <div class="about">
      <svg class="about__seal" width="48" height="48" viewBox="0 0 120 120" fill="none">
        <rect x="5" y="5" width="110" height="110" rx="24" fill="var(--paper)"></rect>
        <g transform="translate(60 60)">
          <path d="M0 0 L0 -34 L17 -18 Z" fill="var(--ink)"></path>
          <path d="M0 0 L0 -34 L17 -18 Z" fill="var(--ink)" transform="rotate(120)"></path>
          <path d="M0 0 L0 -34 L17 -18 Z" fill="var(--accent)" transform="rotate(240)"></path>
          <circle r="6" fill="var(--paper)"></circle>
        </g>
      </svg>
      <h2 class="about__statement">
        A Salesforce-focused consulting &amp; engineering company delivering
        modern CRM solutions across
        <span class="ink-strong"> finance, healthcare, manufacturing</span> and beyond.
      </h2>
      <div class="about__tags">
        {expertise.map((e) => <span class="tag tag--ink">{e}</span>)}
      </div>
    </div>
  </section>

  <!-- ============================ APPLY CTA ============================ -->
  <section id="apply" class="section apply">
    <div class="apply__kanji" aria-hidden="true">未来</div>
    <div class="apply__inner">
      <h2 class="apply__title">
        Ready to <span class="ink-strong">forge the future</span> with us?
      </h2>
      <p class="apply__lede">
        Don't see the perfect role? We're always glad to meet talented people.
        Send us your résumé and tell us what you want to build.
      </p>
      <div class="apply__cta">
        <a href="mailto:careers@miraiforge.tech" class="btn btn--primary apply__mail">
          careers@miraiforge.tech
        </a>
        <a href="#openings" class="btn btn--ghost">Browse roles</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-dept-tab]'));
  const jobs = Array.from(document.querySelectorAll<HTMLElement>('[data-dept-job]'));
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const dept = tab.dataset.deptTab;
      tabs.forEach((t) => t.classList.toggle('is-active', t === tab));
      jobs.forEach((job) => {
        const show = dept === 'All' || job.dataset.deptJob === dept;
        job.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* ---------------- HERO ---------------- */
  .hero {
    position: relative;
    padding: 124px var(--pad-x) 104px;
    text-align: center;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .hero__kanji {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-jp);
    font-weight: 300;
    font-size: 400px;
    line-height: 1;
    color: var(--ink);
    opacity: 0.03;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
  }
  .hero__inner {
    position: relative;
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero__eyebrow {
    color: var(--accent);
    margin-bottom: 28px;
  }
  .hero__title {
    font-size: clamp(32px, 7.5vw, 62px);
    font-weight: 200;
    line-height: 1.08;
    letter-spacing: -0.04em;
    text-align: center;
    text-wrap: balance;
  }
  .hero__title-accent {
    font-weight: 600;
  }
  .hero__lede {
    margin-top: 28px;
    max-width: 620px;
    font-size: 18px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--muted);
  }
  .hero__cta {
    margin-top: 38px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero__stats {
    display: flex;
    gap: 56px;
    margin-top: 48px;
    padding-top: 38px;
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
  }
  .hero__stat-value {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  /* ---------------- shared headings ---------------- */
  .section-heading {
    font-size: 38px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.025em;
    max-width: 620px;
  }
  .section-heading--center {
    max-width: none;
  }
  .section-sub {
    margin-top: 20px;
    max-width: 460px;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--muted);
  }
  .ink-strong {
    font-weight: 600;
  }

  .ink-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: 56px;
  }
  .ink-head__eyebrow {
    color: var(--accent);
  }

  /* chips & tags */
  .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 5px 9px;
    text-transform: uppercase;
  }
  .chip--accent {
    color: var(--accent);
    background: var(--accent-soft);
  }
  .tag {
    font-size: 11.5px;
    padding: 4px 11px;
    border: 1px solid var(--line);
    border-radius: 20px;
    color: var(--muted);
  }
  .tag--ink {
    border-color: color-mix(in oklab, var(--paper) 16%, transparent);
    color: color-mix(in oklab, var(--paper) 80%, transparent);
  }

  /* ---------------- FEATURED ROLES ---------------- */
  .featured__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 46px;
  }
  .featured__all {
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.16s ease;
  }
  .featured__all:hover {
    color: var(--ink);
  }
  .featured__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .rolecard {
    background: var(--paper);
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-height: 188px;
    transition: background 0.18s ease;
  }
  .rolecard:hover {
    background: color-mix(in oklab, var(--paper) 92%, var(--shell));
  }
  .rolecard__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .rolecard__meta {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .rolecard__title {
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .rolecard__loc {
    font-size: 13px;
    color: var(--muted);
  }

  /* ---------------- INK SECTIONS ---------------- */
  .section--ink {
    background: var(--ink);
    color: var(--paper);
  }
  .section--ink .section-heading {
    color: var(--paper);
  }

  .reasons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: color-mix(in oklab, var(--paper) 8%, transparent);
    border: 1px solid color-mix(in oklab, var(--paper) 8%, transparent);
  }
  .reason {
    background: var(--ink);
    padding: 38px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .reason__head {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .reason__n {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    background: var(--accent);
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .reason__title {
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .reason__body {
    font-size: 14px;
    line-height: 1.7;
    font-weight: 300;
    color: color-mix(in oklab, var(--paper) 62%, transparent);
  }
  .reason__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: auto;
    padding-top: 6px;
  }

  /* ---------------- BENEFITS ---------------- */
  .benefits {
    display: grid;
    grid-template-columns: 0.9fr 1.4fr;
    gap: 64px;
    align-items: start;
  }
  .benefits__lead {
    position: sticky;
    top: 108px;
  }
  .benefits__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .benefit {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 22px;
    background: var(--paper);
    font-size: 14.5px;
    line-height: 1.5;
  }
  .benefit__mark {
    color: var(--accent);
    font-weight: 700;
    font-size: 15px;
    line-height: 1.4;
  }

  /* ---------------- OPEN POSITIONS ---------------- */
  .section--alt {
    background: color-mix(in oklab, var(--paper) 60%, var(--shell));
  }
  .ink-head--light .section-heading {
    color: var(--ink);
  }
  .tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 42px;
    flex-wrap: wrap;
  }
  .tab {
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 11px 18px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted);
    transition: all 0.18s ease;
  }
  .tab:hover {
    border-color: var(--ink);
    color: var(--ink);
  }
  .tab.is-active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .listings {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 920px;
    margin: 0 auto;
  }
  .listing {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 22px 26px;
    border: 1px solid var(--line);
    background: var(--paper);
    transition: border-color 0.18s ease;
    flex-wrap: wrap;
  }
  .listing:hover {
    border-color: var(--ink);
  }
  .listing__main {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 240px;
  }
  .listing__titlerow {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .listing__title {
    font-size: 17.5px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .listing__facts {
    display: flex;
    gap: 18px;
    font-size: 13px;
    color: var(--muted);
    flex-wrap: wrap;
  }
  .listing__apply {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--line);
    padding: 11px 18px;
    transition: all 0.18s ease;
  }
  .listing__apply:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

