---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
const cols = [
  {
    title: 'Services',
    links: [
      { href: '#services', label: 'Sales Cloud' },
      { href: '#services', label: 'Service Cloud' },
      { href: '#services', label: 'Experience Cloud' },
      { href: '#services', label: 'Integration & Data' },
      { href: '#services', label: 'Payments & Billing' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '#why', label: 'Why MiraiForge' },
      { href: '#process', label: 'Our Process' },
      { href: '#contact', label: 'Contact' },
    ],
  },
];
---

<footer class="footer">
  <div class="footer__top">
    <div class="footer__brand">
      <Logo size={44} wordSize={26} reversed />
      <p class="footer__tagline">
        Forging Salesforce solutions with craft and precision. Sales, Service
        &amp; Experience Cloud — implemented to last.
      </p>
    </div>

    <div class="footer__cols">
      {cols.map((col) => (
        <div class="footer__col">
          <span class="mono-label">{col.title}</span>
          <ul>
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="footer__bar">
    <span>© {year} MiraiForge Technologies</span>
    <span class="footer__jp">未来を鍛える</span>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--paper);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    padding: 80px var(--pad-x) 64px;
  }

  .footer__tagline {
    margin-top: 26px;
    max-width: 360px;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--faint);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .footer__col ul {
    list-style: none;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__col a {
    font-size: 14px;
    font-weight: 300;
    color: var(--faint);
    transition: color 0.16s ease;
  }
  .footer__col a:hover {
    color: var(--paper);
  }

  .footer__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px var(--pad-x);
    border-top: 1px solid color-mix(in oklab, var(--paper) 14%, transparent);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--faint);
  }

  .footer__jp {
    font-family: var(--font-jp);
    letter-spacing: 0.1em;
  }

  @media (max-width: 860px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px var(--pad-x) 40px;
    }
  }
</style>
