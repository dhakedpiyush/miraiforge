---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'MiraiForge Technologies — Salesforce Consulting',
  description = 'MiraiForge Technologies forges Salesforce solutions — Sales Cloud, Service Cloud and Experience Cloud — implemented with craft and precision.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="MiraiForge Technologies" />
    <meta name="theme-color" content="#1E2026" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@200;300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+JP:wght@300;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="sheet">
      <slot />
    </div>
  </body>
</html>
